{
  "name": "food-orders",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.1.0",
  "workspaces": [
    "domain",
    "apps/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "build": "yarn workspaces foreach -A run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postmerge": "yarn install && yarn build && yarn test",
    "test": "node scripts/test-runner.mjs",
    "test:full": "node scripts/test-runner.mjs full",
    "test:coverage": "node scripts/test-runner.mjs coverage",
    "domain:test": "yarn workspace @food-orders/domain test",
    "domain:build": "yarn workspace @food-orders/domain build",
    "backend:dev": "yarn workspace @food-orders/backend dev",
    "backend:build": "yarn workspace @food-orders/backend build",
    "backend:start": "yarn workspace @food-orders/backend start",
    "frontend:dev": "yarn workspace @food-orders/frontend dev",
    "frontend:build": "yarn workspace @food-orders/frontend build",
    "frontend:storybook": "yarn workspace @food-orders/frontend storybook"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.63.0"
  }
}
