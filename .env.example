# Docker Compose root-level env (used by docker-compose.yml)
POSTGRES_USER=food
POSTGRES_PASSWORD=foodpass
POSTGRES_DB=foodorders

# JWT signing secret — change me in production
JWT_SECRET=please-change-me
JWT_EXPIRES_IN=24h

# Origin that the backend will accept CORS from (the frontend served by nginx)
CORS_ORIGIN=http://localhost:8080

# URL that the frontend bundle will call (compiled into the JS at build time)
PUBLIC_API_URL=http://localhost:3001
